{
  "name": "@monetisebg/circuit-breaker",
  "version": "0.1.0",
  "description": "Circuit breaker for AI agents — pick budget-guard or loop-killer mode and stop runaway token spend or stuck agents in one wrapper. Adapters for LangChain and OpenAI Agents SDK.",
  "keywords": [
    "langchain",
    "langchainjs",
    "openai",
    "openai-agents",
    "agent",
    "circuit-breaker",
    "ai",
    "llm",
    "guardrail",
    "token-limit",
    "budget-guard",
    "loop-killer"
  ],
  "license": "Apache-2.0",
  "author": "MonetiseBG",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MonetiseBG/circuit-breaker.git"
  },
  "bugs": {
    "url": "https://github.com/MonetiseBG/circuit-breaker/issues"
  },
  "homepage": "https://github.com/MonetiseBG/circuit-breaker#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./langchain": {
      "types": "./dist/langchain.d.ts",
      "import": "./dist/langchain.js",
      "require": "./dist/langchain.cjs"
    },
    "./openai-agents": {
      "types": "./dist/openai-agents.d.ts",
      "import": "./dist/openai-agents.js",
      "require": "./dist/openai-agents.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.3.0 <1.0.0",
    "@openai/agents": ">=0.11.0 <1.0.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    },
    "@openai/agents": {
      "optional": true
    }
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "@openai/agents": "^0.11.0",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
